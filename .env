# Database connection for KeyTroupee.
#
# Option 1 (in use): your local MongoDB on this computer. No Atlas needed.
# Use 127.0.0.1 (not "localhost") so Windows connects over IPv4.
MONGODB_URI=mongodb://127.0.0.1:27017/keytroupeeDB

# Option 2 (cloud): to use MongoDB Atlas instead, comment out the line above
# (put a # in front of it) and paste your Atlas string below, then remove the #.
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/keytroupeeDB?retryWrites=true&w=majority

PORT=3000
